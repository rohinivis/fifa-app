<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Log In' }) %>
</head>
<body class="bg-pitch-black text-offwhite font-body min-h-screen">
  <%- include('partials/nav-loader') %>

  <main class="max-w-3xl mx-auto px-6 py-14">
    <div class="max-w-sm mx-auto bg-pitch-dark border border-pitch-line border-t-[3px] border-t-gold rounded-md p-8">
      <h2 class="font-display text-3xl uppercase">Log In</h2>
      <p class="text-gold text-xs uppercase tracking-wide mt-1 mb-4">Step 1 of 2 — Username</p>

      <% if (error) { %>
        <div class="bg-[#3a1414] border border-[#7a2e2e] text-[#f0b4b4] px-4 py-3 rounded-sm text-sm mt-3"><%= error %></div>
      <% } %>

      <form method="POST" action="/login" class="mt-2">
        <label for="username" class="block text-xs uppercase tracking-wide text-muted mt-4 mb-1">Username</label>
        <input type="text" id="username" name="username" required autofocus
          class="w-full px-3 py-2.5 bg-pitch-black border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">

        <button type="submit" class="w-full mt-6 px-8 py-3 rounded-sm bg-gradient-to-br from-gold-bright to-gold text-pitch-black font-semibold uppercase tracking-wide text-sm hover:brightness-110 transition">
          Continue
        </button>
      </form>

      <div class="text-muted text-xs mt-5 leading-relaxed">
        Test accounts:<br>
        <code class="text-gold-bright font-mono">messi_fan</code> / <code class="text-gold-bright font-mono">goat123</code><br>
        <code class="text-gold-bright font-mono">ronaldo_fan</code> / <code class="text-gold-bright font-mono">siuuu2024</code><br>
        <code class="text-gold-bright font-mono">mbappe_fan</code> / <code class="text-gold-bright font-mono">speedster</code>
      </div>
      <div class="text-muted text-xs mt-3">
        Don't have an account? <a href="/signup" class="text-gold-bright hover:underline">Sign up</a>
      </div>
    </div>
  </main>

  <footer class="text-center py-8 text-muted text-xs border-t border-pitch-line">
    Built with Express, EJS, Postgres, and Tailwind — homework edition ⚽
  </footer>
</body>
</html>
