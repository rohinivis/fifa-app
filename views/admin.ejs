<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Admin' }) %>
</head>
<body class="bg-pitch-black text-offwhite font-body min-h-screen">
  <%- include('partials/nav-loader') %>

  <main class="max-w-5xl mx-auto px-6 py-14">
    <div class="mb-10">
      <div class="text-gold text-xs uppercase tracking-[0.2em]">Admin</div>
      <h1 class="font-display text-5xl uppercase mt-2">Manage Squads &amp; Data</h1>
      <p class="text-muted mt-1 text-sm max-w-xl">
        Manage the underlying teams and player pool directly — separate from
        <a href="/account" class="text-gold-bright hover:underline">My Squad</a>, which only
        controls what's in your own account.
      </p>
    </div>

    <!-- TEAMS -->
    <section class="mb-14">
      <h2 class="font-display text-3xl uppercase mb-4">Teams</h2>

      <div class="overflow-x-auto border border-pitch-line rounded-md">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-muted uppercase text-xs tracking-wide bg-pitch-dark">
              <th class="px-4 py-3">Name</th>
              <th class="px-4 py-3">League</th>
              <th class="px-4 py-3">Country</th>
              <th class="px-4 py-3">Players</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody id="teams-table-body">
            <% teams.forEach(function(t) { %>
              <tr class="border-t border-pitch-line" data-team-id="<%= t.id %>" data-team-name="<%= t.name %>">
                <td class="px-4 py-3 font-semibold"><%= t.name %></td>
                <td class="px-4 py-3 text-muted"><%= t.league || '—' %></td>
                <td class="px-4 py-3 text-muted"><%= t.country || '—' %></td>
                <td class="px-4 py-3 font-mono"><%= t.player_count %></td>
                <td class="px-4 py-3 text-right space-x-2 whitespace-nowrap">
                  <button type="button" class="edit-team-btn text-xs uppercase tracking-wide text-gold-bright hover:underline">Edit</button>
                  <button type="button" class="delete-team-btn text-xs uppercase tracking-wide text-[#f0b4b4] hover:underline">Delete</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <form id="add-team-form" class="flex flex-wrap gap-3 items-end mt-4 max-w-2xl">
        <input type="text" name="name" placeholder="Team name" required
          class="flex-1 min-w-[140px] px-3 py-2.5 bg-pitch-dark border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">
        <input type="text" name="league" placeholder="League"
          class="w-40 px-3 py-2.5 bg-pitch-dark border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">
        <input type="text" name="country" placeholder="Country"
          class="w-40 px-3 py-2.5 bg-pitch-dark border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">
        <button type="submit" class="px-5 py-2.5 text-xs uppercase tracking-wide rounded-sm border border-gold text-gold-bright hover:bg-gold hover:text-pitch-black transition">
          Add Team
        </button>
      </form>
      <p id="add-team-status" class="text-muted text-sm mt-2"></p>
    </section>

    <!-- PLAYERS -->
    <section>
      <h2 class="font-display text-3xl uppercase mb-4">Players</h2>

      <div class="overflow-x-auto border border-pitch-line rounded-md">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-muted uppercase text-xs tracking-wide bg-pitch-dark">
              <th class="px-4 py-3">Name</th>
              <th class="px-4 py-3">Team</th>
              <th class="px-4 py-3">Position</th>
              <th class="px-4 py-3">Rating</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody id="players-table-body">
            <% players.forEach(function(p) { %>
              <tr class="border-t border-pitch-line" data-player-id="<%= p.id %>">
                <td class="px-4 py-3 font-semibold"><%= p.name %></td>
                <td class="px-4 py-3">
                  <select class="team-select bg-pitch-dark border border-pitch-line rounded-sm px-2 py-1 text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">
                    <option value="">Free agent</option>
                    <% teams.forEach(function(t) { %>
                      <option value="<%= t.id %>" <%= p.team_id === t.id ? 'selected' : '' %>><%= t.name %></option>
                    <% }); %>
                  </select>
                </td>
                <td class="px-4 py-3 text-muted"><%= p.position %></td>
                <td class="px-4 py-3">
                  <span class="rating-value font-mono"><%= p.rating %></span>
                </td>
                <td class="px-4 py-3 text-right space-x-2 whitespace-nowrap">
                  <button type="button" class="edit-rating-btn text-xs uppercase tracking-wide text-gold-bright hover:underline">Edit Rating</button>
                  <button type="button" class="delete-player-btn text-xs uppercase tracking-wide text-[#f0b4b4] hover:underline">Delete</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <form id="add-player-form" class="flex flex-wrap gap-3 items-end mt-4 max-w-3xl">
        <input type="text" name="name" placeholder="Player name" required
          class="flex-1 min-w-[140px] px-3 py-2.5 bg-pitch-dark border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">
        <select name="team_id"
          class="w-44 px-3 py-2.5 bg-pitch-dark border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">
          <option value="">Free agent</option>
          <% teams.forEach(function(t) { %>
            <option value="<%= t.id %>"><%= t.name %></option>
          <% }); %>
        </select>
        <input type="text" name="position" placeholder="Position" required
          class="w-28 px-3 py-2.5 bg-pitch-dark border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">
        <input type="number" name="rating" placeholder="Rating" min="1" max="99" required
          class="w-24 px-3 py-2.5 bg-pitch-dark border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">
        <button type="submit" class="px-5 py-2.5 text-xs uppercase tracking-wide rounded-sm border border-gold text-gold-bright hover:bg-gold hover:text-pitch-black transition">
          Add Player
        </button>
      </form>
      <p id="add-player-status" class="text-muted text-sm mt-2"></p>
    </section>
  </main>

  <script>
    // ---- Teams ----

    document.getElementById('add-team-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const status = document.getElementById('add-team-status');
      try {
        await FutClubAPI.addTeam({
          name: form.name.value,
          league: form.league.value || null,
          country: form.country.value || null,
        });
        status.textContent = 'Team added. Reloading…';
        setTimeout(() => location.reload(), 400);
      } catch (err) {
        status.textContent = `Error: ${err.message}`;
      }
    });

    document.querySelectorAll('.edit-team-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const row = btn.closest('tr');
        const teamId = row.dataset.teamId;
        const currentName = row.dataset.teamName;
        const nextName = prompt('Team name:', currentName);
        if (nextName === null || nextName === currentName) return;
        try {
          await FutClubAPI.updateTeam(teamId, { name: nextName });
          row.querySelector('td').textContent = nextName;
          row.dataset.teamName = nextName;
        } catch (err) {
          alert(`Error: ${err.message}`);
        }
      });
    });

    document.querySelectorAll('.delete-team-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const row = btn.closest('tr');
        const teamId = row.dataset.teamId;
        const teamName = row.dataset.teamName;
        if (!confirm(`Delete ${teamName}? Its players become free agents, not deleted.`)) return;
        try {
          await FutClubAPI.deleteTeam(teamId);
          location.reload();
        } catch (err) {
          alert(`Error: ${err.message}`);
        }
      });
    });

    // ---- Players ----

    document.getElementById('add-player-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const status = document.getElementById('add-player-status');
      try {
        await FutClubAPI.addPlayer({
          name: form.name.value,
          team_id: form.team_id.value || null,
          position: form.position.value,
          rating: Number(form.rating.value),
        });
        status.textContent = 'Player added. Reloading…';
        setTimeout(() => location.reload(), 400);
      } catch (err) {
        status.textContent = `Error: ${err.message}`;
      }
    });

    document.querySelectorAll('.team-select').forEach((select) => {
      select.addEventListener('change', async () => {
        const row = select.closest('tr');
        const playerId = row.dataset.playerId;
        try {
          await FutClubAPI.updatePlayer(playerId, { team_id: select.value || null });
        } catch (err) {
          alert(`Error: ${err.message}`);
        }
      });
    });

    document.querySelectorAll('.edit-rating-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const row = btn.closest('tr');
        const playerId = row.dataset.playerId;
        const ratingEl = row.querySelector('.rating-value');
        const next = prompt('New rating (1-99):', ratingEl.textContent);
        if (next === null) return;
        try {
          const updated = await FutClubAPI.updatePlayer(playerId, { rating: Number(next) });
          ratingEl.textContent = updated.rating;
        } catch (err) {
          alert(`Error: ${err.message}`);
        }
      });
    });

    document.querySelectorAll('.delete-player-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const row = btn.closest('tr');
        const playerId = row.dataset.playerId;
        if (!confirm('Delete this player entirely? This cannot be undone.')) return;
        try {
          await FutClubAPI.deletePlayer(playerId);
          row.remove();
        } catch (err) {
          alert(`Error: ${err.message}`);
        }
      });
    });
  </script>
</body>
</html>
