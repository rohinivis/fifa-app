<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Sign Up' }) %>
</head>
<body class="bg-pitch-black text-offwhite font-body min-h-screen">
  <%- include('partials/nav-loader') %>

  <main class="max-w-3xl mx-auto px-6 py-14">
    <div class="max-w-sm mx-auto bg-pitch-dark border border-pitch-line border-t-[3px] border-t-gold rounded-md p-8">
      <h2 class="font-display text-3xl uppercase mb-4">Sign Up</h2>

      <% if (error) { %>
        <div class="bg-[#3a1414] border border-[#7a2e2e] text-[#f0b4b4] px-4 py-3 rounded-sm text-sm mb-3"><%= error %></div>
      <% } %>

      <form method="POST" action="/signup">
        <label for="username" class="block text-xs uppercase tracking-wide text-muted mt-2 mb-1">Username</label>
        <input type="text" id="username" name="username" required autofocus
          class="w-full px-3 py-2.5 bg-pitch-black border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">

        <label for="password" class="block text-xs uppercase tracking-wide text-muted mt-4 mb-1">Password</label>
        <input type="password" id="password" name="password" required
          class="w-full px-3 py-2.5 bg-pitch-black border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">

        <label for="favorite_club" class="block text-xs uppercase tracking-wide text-muted mt-4 mb-1">Favorite Club</label>
        <select id="favorite_club" name="favorite_club"
          class="w-full px-3 py-2.5 bg-pitch-black border border-pitch-line rounded-sm text-offwhite focus:outline-none focus:ring-2 focus:ring-gold">
          <option value="">— Select a club —</option>
          <% teams.forEach(function(t) { %>
            <option value="<%= t.name %>"><%= t.name %></option>
          <% }); %>
        </select>

        <button type="submit" class="w-full mt-6 px-8 py-3 rounded-sm bg-gradient-to-br from-gold-bright to-gold text-pitch-black font-semibold uppercase tracking-wide text-sm hover:brightness-110 transition">
          Create Account
        </button>
      </form>

      <div class="text-muted text-xs mt-5">
        Already have an account? <a href="/login" class="text-gold-bright hover:underline">Log in</a>
      </div>
    </div>
  </main>

  <footer class="text-center py-8 text-muted text-xs border-t border-pitch-line">
    Built with Express, EJS, Postgres, and Tailwind — homework edition ⚽
  </footer>
</body>
</html>
